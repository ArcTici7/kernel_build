env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
  ANYKERNEL_SOURCE: https://github.com/osm0sis/AnyKernel3
  ANYKERNEL_SOURCE_BRANCH: master
  KERNEL_SOURCE: https://github.com/ProjectVelvet/kernel_xiaomi_sm6250
  KERNEL_SOURCE_BRANCH: 14.0
  KERNEL_CONFIG: miatoll_defconfig
  BUILD_ARGS: "CONFIG_USB_CONFIGFS_F_UAC2=y CONFIG_USB_CONFIGFS_F_UAC1=y CONFIG_USB_G_AUDIO=y"

steps:
  - name: Checkout Kernel Source
    uses: actions/checkout@v5  # Updated from v4 to v5
